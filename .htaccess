# Route all non-file/directory requests to the PHP proxy index script.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /mail/

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.php [L,QSA]
</IfModule>

Options -Indexes
